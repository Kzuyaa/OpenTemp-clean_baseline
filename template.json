{
  "templateName": "Clean Baseline",
  "description": "V2-compliant clean baseline template. All IDs carry the 'st-' prefix, all colors are driven by CSS variables. Use this as a baseline for testing and as a starting point for new templates.",
  "fields": [
    {
      "id": "st-meta-title",
      "type": "text",
      "label": "Page Title (Meta)",
      "default": "Clean Baseline",
      "targetSelector": "title"
    },
    {
      "id": "st-badge",
      "type": "text",
      "label": "Hero Badge",
      "default": "STABLE BUILD // V2",
      "targetSelector": "#st-badge"
    },
    {
      "id": "st-title",
      "type": "text",
      "label": "Main Heading",
      "default": "Built to Last.",
      "targetSelector": "#st-title"
    },
    {
      "id": "st-subtitle",
      "type": "textarea",
      "label": "Subtitle / Intro",
      "default": "A clean, predictable canvas for testing every V2 editor feature — inline editing, theme switching, and export.",
      "targetSelector": "#st-subtitle"
    },
    {
      "id": "st-cta-primary",
      "type": "text",
      "label": "Primary Button",
      "default": "Get Started",
      "targetSelector": "#st-cta-primary"
    },
    {
      "id": "st-cta-secondary",
      "type": "text",
      "label": "Secondary Link",
      "default": "See How It Works",
      "targetSelector": "#st-cta-secondary"
    },
    {
      "id": "st-pillar-1-title",
      "type": "text",
      "label": "Pillar 1 — Title",
      "default": "Reliable Structure",
      "targetSelector": "#st-pillar-1-title"
    },
    {
      "id": "st-pillar-1-desc",
      "type": "textarea",
      "label": "Pillar 1 — Description",
      "default": "Every element carries a unique ID. No collisions, no guesswork — just clean, predictable DOM.",
      "targetSelector": "#st-pillar-1-desc"
    },
    {
      "id": "st-pillar-2-title",
      "type": "text",
      "label": "Pillar 2 — Title",
      "default": "Full CSS Variable Coverage",
      "targetSelector": "#st-pillar-2-title"
    },
    {
      "id": "st-pillar-2-desc",
      "type": "textarea",
      "label": "Pillar 2 — Description",
      "default": "Every color — from headings to button hovers — is routed through :root variables. Theme swaps are instant.",
      "targetSelector": "#st-pillar-2-desc"
    },
    {
      "id": "st-pillar-3-title",
      "type": "text",
      "label": "Pillar 3 — Title",
      "default": "Editor-Ready Elements",
      "targetSelector": "#st-pillar-3-title"
    },
    {
      "id": "st-pillar-3-desc",
      "type": "textarea",
      "label": "Pillar 3 — Description",
      "default": "All interactive nodes carry .ot-editable-candidate so the inline editor can select and inspect them without configuration.",
      "targetSelector": "#st-pillar-3-desc"
    },
    {
      "id": "st-highlight-number",
      "type": "text",
      "label": "Highlight Stat Value",
      "default": "100%",
      "targetSelector": "#st-highlight-number"
    },
    {
      "id": "st-highlight-label",
      "type": "text",
      "label": "Highlight Stat Label",
      "default": "V2 Compliant",
      "targetSelector": "#st-highlight-label"
    },
    {
      "id": "st-highlight-quote",
      "type": "textarea",
      "label": "Highlight Quote / Pull Text",
      "default": "The best test template is the one you never have to fix. This is that template.",
      "targetSelector": "#st-highlight-quote"
    },
    {
      "id": "st-image",
      "type": "text",
      "label": "Image URL",
      "default": "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1600",
      "targetSelector": "#st-image"
    },
    {
      "id": "st-testimonial-text",
      "type": "textarea",
      "label": "Testimonial Body",
      "default": "This template passed every editor test on the first run. The variable system alone saved us hours of theming work.",
      "targetSelector": "#st-testimonial-text"
    },
    {
      "id": "st-testimonial-author",
      "type": "text",
      "label": "Testimonial Author",
      "default": "OpenTemp Studio",
      "targetSelector": "#st-testimonial-author"
    },
    {
      "id": "st-footer-copy",
      "type": "text",
      "label": "Footer Copyright",
      "default": "OPENTEMP CLEAN BASELINE // 2026",
      "targetSelector": "#st-footer-copy"
    }
  ],
  "defaultTheme": "css/themes/theme-clean-saas.css",
  "supportedThemes": [
    "css/themes/theme-clean-saas.css",
    "css/themes/theme-obsidian.css",
    "css/themes/theme-stark.css",
    "css/themes/theme-nature.css",
    "css/themes/theme-cyberpunk.css",
    "css/themes/theme-gothic.css",
    "css/themes/theme-cosmic.css",
    "css/themes/theme-vintage.css",
    "css/themes/theme-matrix.css",
    "css/themes/theme-pixel.css",
    "css/themes/theme-coquette.css",
    "css/themes/theme-steampunk.css",
    "css/themes/theme-comic.css"
  ]
}
